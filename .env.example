# Application
APP_NAME="Interactive Resume"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_PORT=3000

# Database
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_USER=resume_user
DB_PASSWORD=
DB_NAME=interactive_resume

# Session
SESSION_SECRET=your-session-secret-here

# AI Configuration (if using OpenAI or similar)
OPENAI_API_KEY=
OPENAI_API_KEY=gpt-4-turbo-preview

# WebSocket
WS_PORT=3001

# Theme
DEFAULT_THEME=light

# Mail Configuration
MAIL_DRIVER=log
MAIL_FROM=noreply@resume.local
MAIL_TEMPLATE_PREFIX=emails
MAIL_INLINE_CSS=true
MAIL_TAILWIND=false

# SMTP Configuration (if using SMTP driver)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Alternative Mail Services (uncomment and configure as needed)
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=